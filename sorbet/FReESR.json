                "time": "tha_fgs_epoch"
            },
            "epoch_type": "CDF_EPOCH",
            "file_format": "cdf",
            "description": "Fluxgate magnetometer spin-fit data in GSE coordinates. Vector [Bx,By,Bz]; compute magnitude as needed."
        },
        "density": {
            "dataset": "THA_L2_MOM",
            "url_base": "https://spdf.gsfc.nasa.gov/pub/data/themis/tha/l2/mom/{year}/",
