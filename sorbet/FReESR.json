    "arase": {
        "_info": {
            "name": "Arase (ERG)",
            "orbit": "Highly elliptical, ~400 km to ~32,000 km, ~570 min period",
            "operating": "2017-01-15 to present",
            "archive": "erg",
            "archive_note": "Primary data from ERG Science Center (ergsc.isee.nagoya-u.ac.jp). Some datasets mirrored on CDAWeb with ERG_ prefix. URL patterns below are for the ERG Science Center; CDAWeb mirrors may use different paths."
        },
        "density": {
            "dataset": "ERG_PWE_HFA_L3_1MIN",
            "url_base": "https://ergsc.isee.nagoya-u.ac.jp/data/ergsc/satellite/erg/pwe/hfa/l3/1min/{year}/{month}/",
            "filename_pattern": "erg_pwe_hfa_l3_1min_{date}",
            "variables": {
                "data": "ne_mgf",
                "time": "epoch"
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "cdaweb_fallback": true,
            "description": "Electron density derived from upper hybrid resonance frequency (PWE/HFA L3, 1-min averages)"
        },
        "magnetic field": {
            "dataset": "ERG_MGF_L2_8SEC",
            "url_base": "https://ergsc.isee.nagoya-u.ac.jp/data/ergsc/satellite/erg/mgf/l2/8sec/{year}/{month}/",
            "filename_pattern": "erg_mgf_l2_8sec_{date}",
            "variables": {
                "data": "mag_8sec_sm",
                "time": "epoch_8sec"
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "cdaweb_fallback": true,
            "description": "8-second averaged magnetic field vector in SM coordinates from MGF. Compute magnitude as needed."
        },
        "electron flux": {
            "dataset": "ERG_MEPE_L2_OMNIFLUX",
            "url_base": "https://ergsc.isee.nagoya-u.ac.jp/data/ergsc/satellite/erg/mepe/l2/omniflux/{year}/{month}/",
            "filename_pattern": "erg_mepe_l2_omniflux_{date}",
            "variables": {
                "data": "FEDO",
                "time": "Epoch"
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "cdaweb_fallback": true,
            "description": "Omnidirectional electron flux from MEP-e (~10 keV to ~100 keV). For higher energies use HEP (ERG_HEP_L2_OMNIFLUX)."
        }
    },

    "goes-16": {
        "_info": {
            "name": "GOES-16 (GOES East)",
            "orbit": "Geosynchronous, 75.2 W longitude, L ~ 6.6",
            "operating": "2016-11-19 to present",
            "archive": "ncei",
            "archive_note": "GOES-R series particle data is on NCEI in netCDF format. MAG L2 is also on CDAWeb as DN_MAGN-L2-HIRES_G16. NCEI filenames may include version suffixes; use find_cdf_file pattern matching (works on .nc too)."
        },
        "magnetic field": {
            "dataset": "DN_MAGN-L2-HIRES_G16",
            "url_base": "https://data.ngdc.noaa.gov/platforms/solar-space-observing-satellites/goes/goes16/l2/data/magn-l2-hires/{year}/{month}/",
            "filename_pattern": "dn_magn-l2-hires_g16_d{date}",
            "variables": {
                "data": "b_total",
                "time": "time",
                "support": ["b_epn"]
            },
            "epoch_type": "netcdf_datetime64",
            "file_format": "netcdf",
            "cdaweb_fallback": true,
            "description": "Magnetic field at geosynchronous orbit, 10 Hz (L2 hires). b_total is scalar magnitude, b_epn is [earthward, poleward, normal] vector."
        },
        "electron flux": {
            "dataset": "GOES16_SEISS_MPSH_L2_AVG1M",
            "url_base": "https://data.ngdc.noaa.gov/platforms/solar-space-observing-satellites/goes/goes16/l2/data/seiss-l2-mpsh-avg1m/{year}/{month}/",
            "filename_pattern": "sci_seiss-l2-mpsh-avg1m_g16_d{date}",
            "variables": {
                "data": "AvgDiffElectronFlux",
                "time": "time",
                "support": ["ElectronEffectiveEnergy"]
            },
            "epoch_type": "netcdf_datetime64",
            "file_format": "netcdf",
            "description": "1-minute averaged electron flux from SEISS MPS-HI, 10 differential channels (50 keV to 4 MeV) plus >2 MeV integral. Channels E1 (50-80 keV) and E2 (80-140 keV) are most responsive to substorm injections."
        }
    },

