    "ace": {
        "_info": {
            "name": "Advanced Composition Explorer (ACE)",
            "orbit": "L1 Lagrange point, ~1.5 million km sunward of Earth",
            "operating": "1997-08-25 to present",
            "archive": "cdaweb"
        },
        "magnetic field": {
            "dataset": "AC_H0_MFI",
            "url_base": "https://cdaweb.gsfc.nasa.gov/pub/data/ace/mag/level_2_cdaweb/mfi_h0/{year}/",
            "filename_pattern": "ac_h0_mfi_{date}",
            "variables": {
                "data": "Magnitude",
                "time": "Epoch",
                "support": ["BGSEc"]
            },
            "epoch_type": "CDF_EPOCH",
            "file_format": "cdf",
            "description": "Magnetic field magnitude and GSE components (BGSEc is [Bx,By,Bz]) from MAG/MFI instrument. 16-second resolution."
        },
        "solar wind speed": {
            "dataset": "AC_H0_SWE",
            "url_base": "https://cdaweb.gsfc.nasa.gov/pub/data/ace/swepam/level_2_cdaweb/swe_h0/{year}/",
            "filename_pattern": "ac_h0_swe_{date}",
            "variables": {
                "data": "Vp",
                "time": "Epoch"
            },
            "epoch_type": "CDF_EPOCH",
            "file_format": "cdf",
            "description": "Solar wind proton bulk speed (km/s) from SWEPAM. 64-second resolution."
        },
        "solar wind density": {
            "dataset": "AC_H0_SWE",
            "url_base": "https://cdaweb.gsfc.nasa.gov/pub/data/ace/swepam/level_2_cdaweb/swe_h0/{year}/",
            "filename_pattern": "ac_h0_swe_{date}",
            "variables": {
                "data": "Np",
                "time": "Epoch"
            },
            "epoch_type": "CDF_EPOCH",
            "file_format": "cdf",
            "description": "Solar wind proton number density (cm^-3) from SWEPAM"
        },
        "solar wind temperature": {
            "dataset": "AC_H0_SWE",
            "url_base": "https://cdaweb.gsfc.nasa.gov/pub/data/ace/swepam/level_2_cdaweb/swe_h0/{year}/",
            "filename_pattern": "ac_h0_swe_{date}",
            "variables": {
                "data": "Tpr",
                "time": "Epoch"
            },
            "epoch_type": "CDF_EPOCH",
            "file_format": "cdf",
            "description": "Solar wind proton temperature (K) from SWEPAM"
        }
    },

