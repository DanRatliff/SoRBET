{
    "_meta": {
        "version": "0.2.0",
        "name": "FReESR — Fetch Registry to Explore Space Repositories",
        "description": "SoRBET data registry. Maps friendly spacecraft/quantity names to archive-specific dataset IDs, URL patterns, variable names, and access details. URL templates use {year}, {month}, {date} (YYYYMMDD) and {date_dashed} (YYYY-MM-DD) placeholders.",
        "sources": {
            "cdaweb": "https://cdaweb.gsfc.nasa.gov/WS/cdasr/1/dataviews/sp_phys",
            "spdf": "https://spdf.gsfc.nasa.gov/pub/data",
            "ncei": "https://data.ngdc.noaa.gov/platforms/solar-space-observing-satellites/goes",
            "erg": "https://ergsc.isee.nagoya-u.ac.jp"
        },
        "file_formats": {
            "cdf": "Use cdflib to read",
            "netcdf": "Use netCDF4 or xarray to read"
        },
        "url_template_keys": {
            "year": "4-digit year string, e.g. 2015",
            "month": "2-digit zero-padded month string, e.g. 03",
            "date": "8-digit date string YYYYMMDD, e.g. 20150317",
            "date_dashed": "Dashed date string YYYY-MM-DD, e.g. 2015-03-17"
        }
    },

    "rbsp-a": {
        "_info": {
            "name": "Van Allen Probe A (RBSP-A)",
            "orbit": "Highly elliptical, ~600 km to ~30,600 km, ~9 hr period",
            "operating": "2012-10-01 to 2019-10-18",
            "archive": "cdaweb"
        },
        "density": {
            "dataset": "RBSPA_EMFISIS-L4_DENSITY",
            "url_base": "https://cdaweb.gsfc.nasa.gov/pub/data/rbsp/rbspa/l4/emfisis/density/{year}/",
            "filename_pattern": "rbsp-a_density_emfisis-l4_{date}",
            "variables": {
                "data": "density",
                "time": "Epoch",
                "support": ["bmag"]
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "description": "Electron number density inferred from upper hybrid resonance frequency"
        },
        "magnetic field": {
            "dataset": "RBSPA_EMFISIS-L4_DENSITY",
            "url_base": "https://cdaweb.gsfc.nasa.gov/pub/data/rbsp/rbspa/l4/emfisis/density/{year}/",
            "filename_pattern": "rbsp-a_density_emfisis-l4_{date}",
            "variables": {
                "data": "bmag",
                "time": "Epoch"
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "description": "Magnetic field magnitude from EMFISIS (same file as density)"
        },
        "electron flux": {
            "dataset": "RBSPA_REL04_ECT-MAGEIS-L3",
            "url_base": "https://spdf.gsfc.nasa.gov/pub/data/rbsp/rbspa/l3/ect/mageis/sectors/rel04/{year}/",
            "filename_pattern": "rbspa_rel04_ect-mageis-l3_{date}",
            "variables": {
                "data": "FESA",
                "time": "Epoch",
                "support": ["FESA_Energy", "FEDU", "FEDU_Energy"]
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "description": "Spin-averaged electron flux from MagEIS, 25 energy channels (~20 keV to ~4 MeV). FESA shape is (ntime, 25). Fill value is -1e31."
        },
        "l-shell": {
            "dataset": "RBSPA_REL04_ECT-MAGEIS-L3",
            "url_base": "https://spdf.gsfc.nasa.gov/pub/data/rbsp/rbspa/l3/ect/mageis/sectors/rel04/{year}/",
            "filename_pattern": "rbspa_rel04_ect-mageis-l3_{date}",
            "variables": {
                "data": "L",
                "time": "Epoch",
                "support": ["L_star"]
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "description": "McIlwain L parameter (dipole L-shell). Bundled with ECT flux data. L_star is Roederer L*."
        },
        "mlt": {
            "dataset": "RBSPA_REL04_ECT-MAGEIS-L3",
            "url_base": "https://spdf.gsfc.nasa.gov/pub/data/rbsp/rbspa/l3/ect/mageis/sectors/rel04/{year}/",
            "filename_pattern": "rbspa_rel04_ect-mageis-l3_{date}",
            "variables": {
                "data": "MLT",
                "time": "Epoch"
            },
            "epoch_type": "CDF_TT2000",
            "file_format": "cdf",
            "description": "Magnetic Local Time in hours (0-24). Bundled with ECT flux data."
        }
    },

